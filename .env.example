# Vercel / Production
# Gunakan connection string PostgreSQL dari Vercel Postgres, Supabase, Neon, Railway, atau provider database lain.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Isi dengan random secret panjang. Bisa generate sendiri, minimal 32 karakter.
NEXTAUTH_SECRET="replace-with-a-long-random-secret-minimum-32-chars"

# Setelah domain Vercel jadi, ganti dengan domain production kamu.
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

ADMIN_EMAIL="admin@hpibintan.org"
ADMIN_PASSWORD="AdminHPI2026!"
